DB_HOST=localhost
DB_PORT=3306
DB_NAME=ceibo_db
DB_USER=root
DB_PASSWORD=

JWT_SECRET=change-me-to-a-secure-random-string

# HTTPS (required — server will not start without these)
TLS_CERT_FILE=./certs/server.crt
TLS_KEY_FILE=./certs/server.key

APP_PORT=8443

# CORS — comma-separated allowed origins (default: *)
# CORS_ALLOWED_ORIGINS=https://example.com,https://admin.example.com

# Email (optional — defaults to logger in dev)
# EMAIL_PROVIDER=smtp
# SMTP_HOST=
# SMTP_PORT=
# SMTP_USERNAME=
# SMTP_PASSWORD=
# EMAIL_FROM=noreply@ceibo.com
